{
  "name": "ai-sdlc-system",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram-driven AI SDLC multi-agent system MVP.",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "dev:api": "tsx apps/api/src/index.ts",
    "dev:bot": "tsx apps/telegram-bot/src/index.ts",
    "dev:worker": "tsx apps/worker/src/index.ts",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.12.0",
    "@bull-board/express": "^6.12.0",
    "@octokit/rest": "^21.1.1",
    "bullmq": "^5.34.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "nanoid": "^5.0.9",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "telegraf": "^4.16.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
