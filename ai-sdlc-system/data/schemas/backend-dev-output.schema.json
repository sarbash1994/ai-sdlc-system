{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["branch", "changes", "commands"],
  "additionalProperties": false,
  "properties": {
    "branch": {
      "type": "string",
      "pattern": "^feature/[a-z0-9._/-]+$"
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file", "diff", "rationale"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string" },
          "diff": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
